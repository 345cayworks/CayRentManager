generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  LANDLORD
  PROPERTY_MANAGER
  ACCOUNTANT
  TENANT
  VENDOR
  MAINTENANCE_PROVIDER
  CONCIERGE_AGENT
  GUEST
}

enum UserStatus {
  ACTIVE
  PENDING_INVITE
  INACTIVE
  SUSPENDED
  INVITED
  DISABLED
}

enum RecordStatus {
  ACTIVE
  ARCHIVED
  VOID
  TERMINATED
  INACTIVE
}

enum DocumentVisibility {
  LANDLORD_ONLY
  TENANT_VISIBLE
}

enum DocumentSource {
  EXTERNAL
  STORED
  BROKEN_PLACEHOLDER
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum LeaseEventType {
  EXPIRATION
  RENEWAL_NOTICE
  RENEWAL_DEADLINE
  DEPOSIT_RETURN
  INSPECTION
  NOTICE_TO_VACATE
  RENT_ESCALATION
  DOCUMENT_EXPIRY
  CUSTOM
}

enum LeaseRenewalStatus {
  DRAFT
  PROPOSED
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
}

enum LeaseNoticeType {
  RENEWAL
  NON_RENEWAL
  NOTICE_TO_VACATE
  RENT_INCREASE
  INSPECTION
  DEPOSIT_RETURN
  CUSTOM
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  VOID
}

enum InvoiceStatus {
  NEW
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  COMPLIMENTARY
  MANUAL_OVERRIDE
  PAST_DUE
  GRACE_PERIOD
  INACTIVE
  CANCELLED
}

enum SubscriptionInvoiceStatus {
  DRAFT
  OPEN
  PAID
  WAIVED
  OVERDUE
  PENDING_VERIFICATION
}

enum PaymentMethodType {
  BANK_TRANSFER
  CASH
  CHEQUE
  CARD
  FYGARO_LINK
  POWERTRANZ_CARD
  CNB_GATEWAY
  BUTTERFIELD_GATEWAY
  OTHER
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  ARCHIVED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  APPLIANCE
  GENERAL
  PEST_CONTROL
  SECURITY
  CLEANING
  LANDSCAPING
  OTHER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum LeaseAlertSnapshotStatus {
  ACTIVE
  REVIEWED
  RESOLVED
  DISMISSED
}

enum WorkOrderStatus {
  OPEN
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id                     String       @id @default(cuid())
  netlifyUserId          String?      @unique
  name                   String?
  email                  String       @unique
  emailVerified          DateTime?
  image                  String?
  fullName               String?
  phone                  String?
  role                   UserRole     @default(LANDLORD)
  status                 UserStatus   @default(ACTIVE)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  lastLoginAt            DateTime?
  disabledAt             DateTime?
  disabledBy             String?
  disabledById           String?
  disabledReason         String?
  mustChangePassword     Boolean      @default(false)
  temporaryPasswordHash  String?      @db.Text
  temporaryPasswordSetAt DateTime?
  appSessions            AppSession[]

  accounts                 Account[]
  sessions                 Session[]
  ownedLandlords           LandlordProfile[]      @relation("LandlordOwner")
  memberships              LandlordMembership[]
  tenantProfile            Tenant?
  maintenanceComments      MaintenanceComment[]
  sentMessages             Message[]              @relation("Sender")
  receivedMessages         Message[]              @relation("Receiver")
  auditActions             AuditLog[]             @relation("AuditActor")
  alertPreferences         AlertPreference[]
  outboundNotifications    OutboundNotification[]
  maintenanceVendorProfile MaintenanceVendor?
}

model AppSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LandlordProfile {
  id                        String       @id @default(cuid())
  ownerUserId               String
  companyName               String
  displayName               String
  phone                     String?
  website                   String?
  email                     String?
  addressLine1              String?
  addressLine2              String?
  city                      String?
  country                   String?      @default("KY")
  currency                  String       @default("KYD")
  timezone                  String       @default("America/Cayman")
  tagline                   String?
  logoUrl                   String?
  onboardingCompletedAt     DateTime?
  onboardingCompletedBy     String?
  onboardingDismissedAt     DateTime?
  onboardingDismissedBy     String?
  companyProfileCompletedAt DateTime?
  status                    RecordStatus @default(ACTIVE)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  archivedAt                DateTime?
  archivedBy                String?

  owner                 User                   @relation("LandlordOwner", fields: [ownerUserId], references: [id])
  memberships           LandlordMembership[]
  properties            Property[]
  units                 Unit[]
  tenants               Tenant[]
  invitations           TenantInvitation[]
  leases                Lease[]
  payments              Payment[]
  invoices              Invoice[]
  paymentMethods        PaymentMethod[]
  bankAccounts          BankAccount[]
  expenses              Expense[]
  maintenanceRequests   MaintenanceRequest[]
  maintenanceVendors    MaintenanceVendor[]
  documents             Document[]
  messages              Message[]
  auditLogs             AuditLog[]
  leaseAlertSnapshots   LeaseAlertSnapshot[]
  subscriptions         LandlordSubscription[]
  subscriptionInvoices  SubscriptionInvoice[]
  alertPreferences      AlertPreference[]
  outboundNotifications OutboundNotification[]
  escalationPolicy      EscalationPolicy?
  alertEscalations      AlertEscalation[]
  globalVendorLeads     GlobalVendorLead[]
  vendorPortalRequests  VendorPortalRequest[]
}

model EscalationPolicy {
  id             String   @id @default(cuid())
  landlordId     String   @unique
  enabled        Boolean  @default(true)
  minSeverity    String   @default("URGENT")
  thresholdHours Int      @default(24)
  repeatHours    Int?
  notifyRoles    String[] @default(["LANDLORD", "PROPERTY_MANAGER"])
  channels       String[] @default(["EMAIL"])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  updatedBy      String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
}

model AlertEscalation {
  id              String   @id @default(cuid())
  landlordId      String
  alertKey        String
  level           Int
  severity        String
  notifiedUserIds String[] @default([])
  channels        String[] @default([])
  sentAt          DateTime @default(now())

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])

  @@unique([landlordId, alertKey, level])
  @@index([landlordId, alertKey])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model SubscriptionPlan {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String
  amount         Decimal
  currency       String       @default("KYD")
  intervalMonths Int          @default(1)
  status         RecordStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  subscriptions LandlordSubscription[]
}

model LandlordSubscription {
  id                    String             @id @default(cuid())
  landlordId            String             @unique
  planId                String
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  nextInvoiceAt         DateTime?
  gracePeriodEndsAt     DateTime?
  isComplimentary       Boolean            @default(false)
  complimentarySeats    Int                @default(0)
  complimentaryReason   String?
  complimentaryUntil    DateTime?
  complimentaryByUserId String?
  trialStartsAt         DateTime?
  trialEndsAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  landlord LandlordProfile       @relation(fields: [landlordId], references: [id])
  plan     SubscriptionPlan      @relation(fields: [planId], references: [id])
  invoices SubscriptionInvoice[]
}

model SubscriptionInvoice {
  id               String                    @id @default(cuid())
  subscriptionId   String
  landlordId       String
  invoiceNumber    String                    @unique
  amount           Decimal
  currency         String                    @default("KYD")
  status           SubscriptionInvoiceStatus @default(OPEN)
  dueDate          DateTime
  paidAt           DateTime?
  waivedAt         DateTime?
  fygaroCustomRef  String?                   @unique
  fygaroPaymentUrl String?
  fygaroPaymentId  String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  subscription  LandlordSubscription  @relation(fields: [subscriptionId], references: [id])
  landlord      LandlordProfile       @relation(fields: [landlordId], references: [id])
  paymentEvents BillingPaymentEvent[]

  @@index([subscriptionId, status])
  @@index([landlordId, status])
}

model BillingPaymentEvent {
  id                    String   @id @default(cuid())
  subscriptionInvoiceId String
  eventType             String
  provider              String   @default("FYGARO")
  providerReference     String?
  payload               Json?
  createdAt             DateTime @default(now())

  invoice SubscriptionInvoice @relation(fields: [subscriptionInvoiceId], references: [id], onDelete: Cascade)

  @@index([subscriptionInvoiceId, createdAt])
}

model LandlordMembership {
  id         String       @id @default(cuid())
  landlordId String
  userId     String
  role       UserRole
  status     RecordStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  user     User            @relation(fields: [userId], references: [id])

  @@unique([landlordId, userId])
}

model Property {
  id             String       @id @default(cuid())
  landlordId     String
  name           String
  address        String
  city           String
  state          String
  country        String       @default("US")
  propertyType   String       @default("Residential")
  purchasePrice  Decimal?
  estimatedValue Decimal?
  status         RecordStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  archivedAt     DateTime?
  archivedBy     String?

  landlord            LandlordProfile      @relation(fields: [landlordId], references: [id])
  units               Unit[]
  invitations         TenantInvitation[]
  leases              Lease[]
  payments            Payment[]
  invoices            Invoice[]
  expenses            Expense[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]
  photos              PropertyPhoto[]
}

model Unit {
  id            String       @id @default(cuid())
  landlordId    String
  propertyId    String
  unitName      String
  bedrooms      Int?
  bathrooms     Decimal?
  squareFeet    Int?
  rentAmount    Decimal
  depositAmount Decimal?
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  archivedAt    DateTime?
  archivedBy    String?

  landlord            LandlordProfile      @relation(fields: [landlordId], references: [id])
  property            Property             @relation(fields: [propertyId], references: [id])
  invitations         TenantInvitation[]
  leases              Lease[]
  payments            Payment[]
  invoices            Invoice[]
  expenses            Expense[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]
  photos              UnitPhoto[]
}

model PropertyPhoto {
  id          String    @id @default(cuid())
  landlordId  String
  propertyId  String
  storageKey  String
  fileName    String
  contentType String
  fileSize    Int
  isPrimary   Boolean   @default(false)
  sortOrder   Int       @default(0)
  uploadedBy  String
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([landlordId])
}

model UnitPhoto {
  id          String    @id @default(cuid())
  landlordId  String
  unitId      String
  storageKey  String
  fileName    String
  contentType String
  fileSize    Int
  isPrimary   Boolean   @default(false)
  sortOrder   Int       @default(0)
  uploadedBy  String
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([landlordId])
}

model Tenant {
  id                    String       @id @default(cuid())
  landlordId            String
  userId                String?      @unique
  fullName              String
  email                 String
  phone                 String?
  employer              String?
  emergencyContactName  String?
  emergencyContactPhone String?
  status                RecordStatus @default(ACTIVE)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  deactivatedAt         DateTime?
  deactivatedBy         String?

  landlord            LandlordProfile      @relation(fields: [landlordId], references: [id])
  user                User?                @relation(fields: [userId], references: [id])
  leases              Lease[]
  payments            Payment[]
  invoices            Invoice[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]

  @@unique([landlordId, email])
}

model TenantInvitation {
  id          String           @id @default(cuid())
  landlordId  String
  propertyId  String?
  unitId      String?
  email       String
  phone       String?
  inviteToken String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  property Property?       @relation(fields: [propertyId], references: [id])
  unit     Unit?           @relation(fields: [unitId], references: [id])
}

model Lease {
  id            String      @id @default(cuid())
  landlordId    String
  propertyId    String
  unitId        String
  tenantId      String
  startDate     DateTime
  endDate       DateTime
  rentAmount    Decimal
  depositAmount Decimal?
  lateFeeAmount Decimal?
  status        LeaseStatus @default(ACTIVE)
  leasePdfUrl   String?
  signedPdfUrl  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  terminatedAt  DateTime?
  terminatedBy  String?

  landlord         LandlordProfile        @relation(fields: [landlordId], references: [id])
  property         Property               @relation(fields: [propertyId], references: [id])
  unit             Unit                   @relation(fields: [unitId], references: [id])
  tenant           Tenant                 @relation(fields: [tenantId], references: [id])
  invoices         Invoice[]
  payments         Payment[]
  documents        Document[]
  events           LeaseEvent[]
  renewals         LeaseRenewal[]
  notices          LeaseNotice[]
  documentVersions LeaseDocumentVersion[]
}

model LeaseEvent {
  id          String         @id @default(cuid())
  landlordId  String
  leaseId     String
  eventType   LeaseEventType
  eventDate   DateTime
  description String?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([landlordId, eventDate])
  @@index([leaseId, eventType])
}

model LeaseRenewal {
  id                 String             @id @default(cuid())
  landlordId         String
  leaseId            String
  renewalStartDate   DateTime
  renewalEndDate     DateTime
  proposedRentAmount Decimal?
  status             LeaseRenewalStatus @default(DRAFT)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  acceptedAt         DateTime?
  completedAt        DateTime?

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([landlordId, status])
  @@index([leaseId, renewalStartDate])
}

model LeaseNotice {
  id         String          @id @default(cuid())
  landlordId String
  leaseId    String
  noticeType LeaseNoticeType
  noticeDate DateTime
  content    String
  sentAt     DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([landlordId, noticeDate])
  @@index([leaseId, noticeType])
}

model LeaseDocumentVersion {
  id            String   @id @default(cuid())
  landlordId    String
  leaseId       String
  fileUrl       String
  fileName      String?
  documentType  String?
  versionNumber Int
  uploadedAt    DateTime @default(now())

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@unique([leaseId, versionNumber])
  @@index([landlordId, uploadedAt])
}

model LeaseAlertSnapshot {
  id            String                   @id @default(cuid())
  landlordId    String
  alertKey      String
  type          String
  severity      String
  title         String
  description   String
  leaseId       String?
  tenantId      String?
  propertyId    String?
  unitId        String?
  daysRemaining Int?
  amount        Decimal?
  status        LeaseAlertSnapshotStatus @default(ACTIVE)
  firstSeenAt   DateTime                 @default(now())
  lastSeenAt    DateTime                 @default(now())
  reviewedAt    DateTime?
  resolvedAt    DateTime?
  dismissedAt   DateTime?
  metadata      Json?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])

  @@unique([landlordId, alertKey])
  @@index([landlordId, status])
  @@index([landlordId, severity])
  @@index([leaseId])
  @@index([lastSeenAt])
}

model Invoice {
  id         String        @id @default(cuid())
  invoiceNo  String        @unique
  landlordId String
  tenantId   String
  leaseId    String
  propertyId String
  unitId     String
  amount     Decimal
  amountPaid Decimal       @default(0)
  balance    Decimal
  dueDate    DateTime
  sentAt     DateTime?
  paidAt     DateTime?
  status     InvoiceStatus @default(NEW)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  voidedAt   DateTime?
  voidedBy   String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  lease    Lease           @relation(fields: [leaseId], references: [id])
  property Property        @relation(fields: [propertyId], references: [id])
  unit     Unit            @relation(fields: [unitId], references: [id])
  payments Payment[]

  @@index([landlordId, dueDate])
  @@index([landlordId, status])
  @@index([tenantId, status])
}

model Payment {
  id              String        @id @default(cuid())
  landlordId      String
  tenantId        String
  leaseId         String
  propertyId      String
  unitId          String
  invoiceId       String?
  paymentMethodId String?
  dueDate         DateTime
  paymentDate     DateTime?
  amountDue       Decimal
  amountPaid      Decimal?      @default(0)
  balance         Decimal
  paymentMethod   String?
  status          PaymentStatus @default(PENDING)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  voidedAt        DateTime?
  voidedBy        String?

  landlord      LandlordProfile @relation(fields: [landlordId], references: [id])
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  lease         Lease           @relation(fields: [leaseId], references: [id])
  property      Property        @relation(fields: [propertyId], references: [id])
  unit          Unit            @relation(fields: [unitId], references: [id])
  invoice       Invoice?        @relation(fields: [invoiceId], references: [id])
  method        PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  receipt       Receipt?
  paymentProofs PaymentProof[]
}

model Receipt {
  id        String   @id @default(cuid())
  paymentId String   @unique
  fileUrl   String?
  receiptNo String   @unique
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
}

model PaymentProof {
  id         String   @id @default(cuid())
  paymentId  String
  fileUrl    String
  fileType   String?
  uploadedAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
}

model PaymentMethod {
  id         String            @id @default(cuid())
  landlordId String
  type       PaymentMethodType
  label      String
  details    Json?
  isDefault  Boolean           @default(false)
  status     RecordStatus      @default(ACTIVE)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  archivedAt DateTime?
  archivedBy String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  payments Payment[]

  @@index([landlordId, type])
  @@index([landlordId, status])
}

model BankAccount {
  id                  String       @id @default(cuid())
  landlordId          String
  bankName            String
  accountName         String?
  accountNumberMasked String
  branch              String?
  swiftCode           String?
  routingInfo         String?
  isDefault           Boolean      @default(false)
  status              RecordStatus @default(ACTIVE)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  archivedAt          DateTime?
  archivedBy          String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])

  @@index([landlordId, status])
}

model Expense {
  id          String       @id @default(cuid())
  landlordId  String
  propertyId  String
  unitId      String?
  category    String
  vendor      String?
  amount      Decimal
  expenseDate DateTime
  receiptUrl  String?
  description String?
  status      RecordStatus @default(ACTIVE)
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  voidedAt    DateTime?
  voidedBy    String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  property Property        @relation(fields: [propertyId], references: [id])
  unit     Unit?           @relation(fields: [unitId], references: [id])
}

model MaintenanceRequest {
  id                   String              @id @default(cuid())
  landlordId           String
  tenantId             String?
  propertyId           String
  unitId               String?
  title                String
  description          String
  category             MaintenanceCategory @default(GENERAL)
  priority             MaintenancePriority @default(MEDIUM)
  status               MaintenanceStatus   @default(OPEN)
  permissionToEnter    Boolean             @default(false)
  preferredContactTime String?
  assignedVendorId     String?
  estimatedCost        Decimal?
  finalCost            Decimal?
  contractorName       String?
  photoUrl             String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  archivedAt           DateTime?
  archivedBy           String?
  slaDueAt             DateTime?
  slaBreachedAt        DateTime?
  firstResponseAt      DateTime?
  resolvedAt           DateTime?

  landlord    LandlordProfile         @relation(fields: [landlordId], references: [id])
  tenant      Tenant?                 @relation(fields: [tenantId], references: [id])
  property    Property                @relation(fields: [propertyId], references: [id])
  unit        Unit?                   @relation(fields: [unitId], references: [id])
  vendor      MaintenanceVendor?      @relation(fields: [assignedVendorId], references: [id])
  attachments MaintenanceAttachment[]
  comments    MaintenanceComment[]
  workOrders  MaintenanceWorkOrder[]

  @@index([landlordId, slaDueAt])
}

model MaintenanceAttachment {
  id                   String   @id @default(cuid())
  maintenanceRequestId String
  landlordId           String?
  fileUrl              String?
  storageKey           String?
  fileSize             Int?
  fileType             String?
  uploadedBy           String?
  uploadedAt           DateTime @default(now())

  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)

  @@index([maintenanceRequestId])
}

model MaintenanceComment {
  id                   String   @id @default(cuid())
  maintenanceRequestId String
  authorUserId         String
  message              String
  createdAt            DateTime @default(now())

  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
  author             User               @relation(fields: [authorUserId], references: [id])

  @@index([maintenanceRequestId, createdAt])
}

model MaintenanceVendor {
  id                 String    @id @default(cuid())
  landlordId         String
  name               String
  email              String?
  phone              String?
  specialty          String?
  approvedStatus     Boolean   @default(false)
  notes              String?
  address            String?
  licenseNumber      String?
  insuranceExpiresAt DateTime?
  userId             String?   @unique
  portalEnabledAt    DateTime?
  globalVendorId     String?
  archivedAt         DateTime?
  archivedBy         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  landlord         LandlordProfile        @relation(fields: [landlordId], references: [id])
  user             User?                  @relation(fields: [userId], references: [id])
  globalVendor     GlobalVendor?          @relation(fields: [globalVendorId], references: [id])
  assignedRequests MaintenanceRequest[]
  workOrders       MaintenanceWorkOrder[]
  portalRequests   VendorPortalRequest[]

  @@index([landlordId])
  @@index([landlordId, archivedAt])
  @@index([globalVendorId])
}

model VendorPortalRequest {
  id                  String    @id @default(cuid())
  landlordId          String
  maintenanceVendorId String
  requestedByUserId   String
  requestedEmail      String
  status              String    @default("PENDING") // PENDING|APPROVED|REJECTED|CANCELLED
  note                String?
  reviewedByUserId    String?
  reviewedAt          DateTime?
  decisionNote        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  landlord LandlordProfile   @relation(fields: [landlordId], references: [id])
  vendor   MaintenanceVendor @relation(fields: [maintenanceVendorId], references: [id])

  @@index([status])
  @@index([landlordId])
  @@index([maintenanceVendorId])
}

model GlobalVendor {
  id             String       @id @default(cuid())
  name           String
  email          String?
  phone          String?
  website        String?
  specialty      String?
  serviceAreas   String?
  description    String?
  logoUrl        String?
  approvedStatus Boolean      @default(false)
  featured       Boolean      @default(false)
  sponsored      Boolean      @default(false)
  monthlyFee     Decimal?
  billingStatus  String       @default("NONE") // NONE|TRIAL|ACTIVE|PAST_DUE|CANCELLED
  billingNotes   String?
  paidThrough    DateTime?
  status         RecordStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  archivedAt     DateTime?
  archivedBy     String?
  createdBy      String?

  localCopies MaintenanceVendor[]
  leads       GlobalVendorLead[]

  @@index([status])
  @@index([approvedStatus])
}

model GlobalVendorLead {
  id             String   @id @default(cuid())
  globalVendorId String
  landlordId     String
  type           String // ADD_TO_LIST | INQUIRY
  note           String?
  createdAt      DateTime @default(now())

  globalVendor GlobalVendor    @relation(fields: [globalVendorId], references: [id])
  landlord     LandlordProfile @relation(fields: [landlordId], references: [id])

  @@index([globalVendorId])
  @@index([globalVendorId, type])
  @@index([landlordId])
}

model MaintenanceWorkOrder {
  id                   String          @id @default(cuid())
  maintenanceRequestId String
  vendorId             String?
  status               WorkOrderStatus @default(OPEN)
  estimatedCost        Decimal?
  actualCost           Decimal?
  scheduledDate        DateTime?
  dispatchedAt         DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  completionNotes      String?
  vendorAcknowledgedAt DateTime?
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
  vendor             MaintenanceVendor? @relation(fields: [vendorId], references: [id])

  @@index([maintenanceRequestId])
}

model Document {
  id           String             @id @default(cuid())
  landlordId   String
  propertyId   String?
  unitId       String?
  tenantId     String?
  leaseId      String?
  documentType String
  fileName     String
  fileUrl      String
  storageKey   String?
  fileSize     Int?
  contentType  String?
  visibility   DocumentVisibility @default(LANDLORD_ONLY)
  source       DocumentSource     @default(EXTERNAL)
  status       RecordStatus       @default(ACTIVE)
  uploadedBy   String
  createdAt    DateTime           @default(now())
  archivedAt   DateTime?
  archivedBy   String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  property Property?       @relation(fields: [propertyId], references: [id])
  unit     Unit?           @relation(fields: [unitId], references: [id])
  tenant   Tenant?         @relation(fields: [tenantId], references: [id])
  lease    Lease?          @relation(fields: [leaseId], references: [id])
}

model Message {
  id         String    @id @default(cuid())
  landlordId String
  senderId   String
  receiverId String
  propertyId String?
  unitId     String?
  subject    String
  message    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  sender   User            @relation("Sender", fields: [senderId], references: [id])
  receiver User            @relation("Receiver", fields: [receiverId], references: [id])

  @@index([landlordId, receiverId, readAt])
  @@index([landlordId, senderId])
  @@index([landlordId, createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  landlordId   String?
  actorUserId  String
  actorEmail   String
  action       String
  entityType   String
  entityId     String
  targetUserId String?
  targetEmail  String?
  details      Json
  createdAt    DateTime @default(now())

  landlord LandlordProfile? @relation(fields: [landlordId], references: [id])
  actor    User             @relation("AuditActor", fields: [actorUserId], references: [id])
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

model AlertPreference {
  id              String   @id @default(cuid())
  landlordId      String
  userId          String
  digestEnabled   Boolean  @default(true)
  minSeverity     String   @default("WARNING")
  suppressedTypes String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  user     User            @relation(fields: [userId], references: [id])

  @@unique([landlordId, userId])
  @@index([landlordId])
}

model OutboundNotification {
  id                String              @id @default(cuid())
  landlordId        String?
  recipientUserId   String?
  recipientEmail    String
  recipientPhone    String?
  notificationKind  String              @default("GENERAL")
  channel           NotificationChannel @default(EMAIL)
  subject           String
  body              String              @db.Text
  bodyHtml          String?             @db.Text
  relatedAlertKeys  String[]            @default([])
  status            NotificationStatus  @default(PENDING)
  provider          String?
  providerMessageId String?
  failureReason     String?
  attemptCount      Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  sentAt            DateTime?

  landlord  LandlordProfile? @relation(fields: [landlordId], references: [id])
  recipient User?            @relation(fields: [recipientUserId], references: [id])

  @@index([status, createdAt])
  @@index([landlordId, createdAt])
}
