# =============================================================================
# CayRentManager environment reference
# -----------------------------------------------------------------------------
# Copy to .env.local for local dev. On Netlify, set these in Site settings →
# Environment variables. Keep all secrets as long random values; the
# placeholders below are NOT safe defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Core (required)
# -----------------------------------------------------------------------------
# Postgres connection string for Prisma. On Netlify the managed Netlify DB
# connection is auto-provisioned and exposed as NETLIFY_DB_URL — the app falls
# back to NETLIFY_DB_URL when DATABASE_URL is unset, so you usually do NOT need
# to set DATABASE_URL on Netlify. Set it explicitly for local dev / external DB.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rentflow?schema=public"

# Secret used to sign/verify the app session cookie. Long random value.
# Rotating this invalidates all active sessions (see docs/BACKUP_RECOVERY.md).
APP_SESSION_SECRET="replace-me-with-long-random-value"

# Public base URL of the deployment (used to build absolute links/emails).
# This is the single canonical base-url variable — do not reintroduce others.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Superadmin / bootstrap
# -----------------------------------------------------------------------------
# Email that is granted the SUPERADMIN role on first session sync.
SUPER_ADMIN_EMAIL="owner@example.com"

# Emergency superadmin bootstrap key. Never expose publicly; for break-glass
# recovery only.
SUPERADMIN_MASTER_KEY="replace-me-with-long-random-value"

# Gate for the one-time bootstrap-owner route. MUST be unset (or "false") in
# steady-state production. Only set "true" briefly during initial provisioning,
# then unset it again.
# ENABLE_BOOTSTRAP_OWNER_ROUTE="false"

# Optional comma-separated IP allowlist for the bootstrap route while enabled.
# BOOTSTRAP_ALLOWED_IPS="203.0.113.10,203.0.113.11"

# -----------------------------------------------------------------------------
# Email notifications (optional)
# -----------------------------------------------------------------------------
# The notification outbox defaults to a log-only driver — leave these unset to
# keep deploys safe. Set NOTIFICATION_PROVIDER="resend" plus the related vars
# to activate live email sends.
# NOTIFICATION_PROVIDER="resend"
# RESEND_API_KEY="re_replace_me"
# NOTIFICATION_FROM_EMAIL="alerts@yourdomain.com"
# NOTIFICATION_FROM_NAME="CayRentManager"

# -----------------------------------------------------------------------------
# SMS / WhatsApp (optional, Twilio)
# -----------------------------------------------------------------------------
# Leave unset to keep SMS/WhatsApp channels in log-only mode.
# SMS_PROVIDER="twilio"
# WHATSAPP_PROVIDER="twilio"
# TWILIO_ACCOUNT_SID="AC_replace_me"
# TWILIO_AUTH_TOKEN="replace-me-with-twilio-auth-token"
# TWILIO_SMS_FROM="+1xxxxxxxxxx"
# TWILIO_WHATSAPP_FROM="whatsapp:+1xxxxxxxxxx"

# -----------------------------------------------------------------------------
# Billing / Fygaro (optional)
# -----------------------------------------------------------------------------
# Required only when collecting subscription/rent payments via Fygaro.
# FYGARO_BUTTON_URL="https://www.fygaro.com/en/pb/replace-me"
# FYGARO_KID="replace-me-with-fygaro-key-id"
# FYGARO_PUBLIC_KEY="replace-me-with-fygaro-public-key"
# FYGARO_SECRET_KEY="replace-me-with-fygaro-secret-key"
# FYGARO_WEBHOOK_SECRET — REQUIRED for webhook-confirmed payments. The Fygaro
# webhook handler fails CLOSED: when this is unset/empty every inbound webhook
# is REJECTED with 401, and payment confirmation falls back to the SuperAdmin
# manual mark-paid flow. Set this (and confirm Fygaro's real webhook scheme +
# header in the Fygaro dashboard) before relying on automatic confirmation.
# FYGARO_WEBHOOK_SECRET="replace-me-with-fygaro-webhook-secret"
#
# Billing access enforcement (SHIPPED DARK; default OFF). Leave UNSET (or any
# value other than the literal "true") to keep enforcement OFF — no landlord
# is ever locked out by default. WARNING: only set "true" AFTER the Phase 3
# backfill is verified and every active landlord has a TRIAL subscription;
# enabling it locks out INACTIVE non-complimentary landlords.
# BILLING_ENFORCEMENT_ENABLED="false"

# -----------------------------------------------------------------------------
# Netlify-managed (no action needed)
# -----------------------------------------------------------------------------
# - Netlify Blobs (document & photo storage) is auto-provisioned on Netlify;
#   no env var is required.
# - The Netlify DB connection is auto-provisioned and surfaced as
#   NETLIFY_DB_URL, which is the managed fallback for DATABASE_URL.
# - NODE_ENV is set automatically by the platform/build.
