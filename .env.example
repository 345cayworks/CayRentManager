DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rentflow?schema=public"
APP_SESSION_SECRET="replace-me-with-long-random-value"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SUPER_ADMIN_EMAIL="owner@example.com"
SUPERADMIN_MASTER_KEY="replace-me-with-long-random-value"

# CayRentManager uses Netlify Identity for authentication.
# Enable Netlify Identity in the Netlify UI and set APP_SESSION_SECRET in production.
# SUPERADMIN_MASTER_KEY is emergency bootstrap only and must never be public.
