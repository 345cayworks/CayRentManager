generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  LANDLORD
  PROPERTY_MANAGER
  ACCOUNTANT
  TENANT
  VENDOR
  MAINTENANCE_PROVIDER
  CONCIERGE_AGENT
  GUEST
}

enum UserStatus {
  ACTIVE
  PENDING_INVITE
  INACTIVE
  SUSPENDED
  INVITED
  DISABLED
}

enum RecordStatus {
  ACTIVE
  ARCHIVED
  VOID
  TERMINATED
  INACTIVE
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  VOID
}

enum InvoiceStatus {
  NEW
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum PaymentMethodType {
  BANK_TRANSFER
  CASH
  CHEQUE
  CARD
  FYGARO_LINK
  POWERTRANZ_CARD
  CNB_GATEWAY
  BUTTERFIELD_GATEWAY
  OTHER
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  ARCHIVED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model User {
  id             String    @id @default(cuid())
  netlifyUserId  String?   @unique
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  fullName       String?
  phone          String?
  role           UserRole   @default(LANDLORD)
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastLoginAt             DateTime?
  disabledAt              DateTime?
  disabledBy              String?
  disabledById            String?
  disabledReason          String?
  mustChangePassword      Boolean   @default(false)
  temporaryPasswordHash   String?   @db.Text
  temporaryPasswordSetAt  DateTime?
  appSessions             AppSession[]

  accounts         Account[]
  sessions         Session[]
  ownedLandlords   LandlordProfile[] @relation("LandlordOwner")
  memberships      LandlordMembership[]
  tenantProfile    Tenant?
  sentMessages     Message[] @relation("Sender")
  receivedMessages Message[] @relation("Receiver")
  auditActions     AuditLog[] @relation("AuditActor")
}

model AppSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LandlordProfile {
  id          String       @id @default(cuid())
  ownerUserId String
  companyName String
  displayName String
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  archivedAt  DateTime?
  archivedBy  String?

  owner               User                 @relation("LandlordOwner", fields: [ownerUserId], references: [id])
  memberships         LandlordMembership[]
  properties          Property[]
  units               Unit[]
  tenants             Tenant[]
  invitations         TenantInvitation[]
  leases              Lease[]
  payments            Payment[]
  invoices            Invoice[]
  paymentMethods      PaymentMethod[]
  bankAccounts        BankAccount[]
  expenses            Expense[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]
  messages            Message[]
  auditLogs           AuditLog[]
}

model LandlordMembership {
  id         String       @id @default(cuid())
  landlordId String
  userId     String
  role       UserRole
  status     RecordStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  user     User            @relation(fields: [userId], references: [id])

  @@unique([landlordId, userId])
}

model Property {
  id             String       @id @default(cuid())
  landlordId     String
  name           String
  address        String
  city           String
  state          String
  country        String       @default("US")
  propertyType   String       @default("Residential")
  purchasePrice  Decimal?
  estimatedValue Decimal?
  status         RecordStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  archivedAt     DateTime?
  archivedBy     String?

  landlord            LandlordProfile     @relation(fields: [landlordId], references: [id])
  units               Unit[]
  invitations         TenantInvitation[]
  leases              Lease[]
  payments            Payment[]
  invoices            Invoice[]
  expenses            Expense[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]
}

model Unit {
  id            String       @id @default(cuid())
  landlordId    String
  propertyId    String
  unitName      String
  bedrooms      Int?
  bathrooms     Decimal?
  squareFeet    Int?
  rentAmount    Decimal
  depositAmount Decimal?
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  archivedAt    DateTime?
  archivedBy    String?

  landlord            LandlordProfile     @relation(fields: [landlordId], references: [id])
  property            Property            @relation(fields: [propertyId], references: [id])
  invitations         TenantInvitation[]
  leases              Lease[]
  payments            Payment[]
  invoices            Invoice[]
  expenses            Expense[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]
}

model Tenant {
  id                    String       @id @default(cuid())
  landlordId            String
  userId                String?      @unique
  fullName              String
  email                 String
  phone                 String?
  employer              String?
  emergencyContactName  String?
  emergencyContactPhone String?
  status                RecordStatus @default(ACTIVE)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  deactivatedAt         DateTime?
  deactivatedBy         String?

  landlord            LandlordProfile     @relation(fields: [landlordId], references: [id])
  user                User?               @relation(fields: [userId], references: [id])
  leases              Lease[]
  payments            Payment[]
  invoices            Invoice[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]

  @@unique([landlordId, email])
}

model TenantInvitation {
  id          String           @id @default(cuid())
  landlordId  String
  propertyId  String?
  unitId      String?
  email       String
  phone       String?
  inviteToken String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  property Property?       @relation(fields: [propertyId], references: [id])
  unit     Unit?           @relation(fields: [unitId], references: [id])
}

model Lease {
  id            String      @id @default(cuid())
  landlordId    String
  propertyId    String
  unitId        String
  tenantId      String
  startDate     DateTime
  endDate       DateTime
  rentAmount    Decimal
  depositAmount Decimal?
  lateFeeAmount Decimal?
  status        LeaseStatus @default(ACTIVE)
  leasePdfUrl   String?
  signedPdfUrl  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  terminatedAt  DateTime?
  terminatedBy  String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  property Property        @relation(fields: [propertyId], references: [id])
  unit     Unit            @relation(fields: [unitId], references: [id])
  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  invoices Invoice[]
  payments Payment[]
  documents Document[]
}

model Invoice {
  id          String        @id @default(cuid())
  invoiceNo   String        @unique
  landlordId  String
  tenantId    String
  leaseId     String
  propertyId  String
  unitId      String
  amount      Decimal
  amountPaid  Decimal       @default(0)
  balance     Decimal
  dueDate     DateTime
  sentAt      DateTime?
  paidAt      DateTime?
  status      InvoiceStatus @default(NEW)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  voidedAt    DateTime?
  voidedBy    String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  lease    Lease           @relation(fields: [leaseId], references: [id])
  property Property        @relation(fields: [propertyId], references: [id])
  unit     Unit            @relation(fields: [unitId], references: [id])
  payments Payment[]

  @@index([landlordId, dueDate])
  @@index([landlordId, status])
  @@index([tenantId, status])
}

model Payment {
  id              String        @id @default(cuid())
  landlordId      String
  tenantId        String
  leaseId         String
  propertyId      String
  unitId          String
  invoiceId       String?
  paymentMethodId String?
  dueDate         DateTime
  paymentDate     DateTime?
  amountDue       Decimal
  amountPaid      Decimal?      @default(0)
  balance         Decimal
  paymentMethod   String?
  status          PaymentStatus @default(PENDING)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  voidedAt        DateTime?
  voidedBy        String?

  landlord      LandlordProfile @relation(fields: [landlordId], references: [id])
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  lease         Lease           @relation(fields: [leaseId], references: [id])
  property      Property        @relation(fields: [propertyId], references: [id])
  unit          Unit            @relation(fields: [unitId], references: [id])
  invoice       Invoice?        @relation(fields: [invoiceId], references: [id])
  method        PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  receipt       Receipt?
  paymentProofs PaymentProof[]
}

model Receipt {
  id        String   @id @default(cuid())
  paymentId String   @unique
  fileUrl   String?
  receiptNo String   @unique
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
}

model PaymentProof {
  id         String   @id @default(cuid())
  paymentId  String
  fileUrl    String
  fileType   String?
  uploadedAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
}

model PaymentMethod {
  id          String            @id @default(cuid())
  landlordId  String
  type        PaymentMethodType
  label       String
  details     Json?
  isDefault   Boolean           @default(false)
  status      RecordStatus      @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  archivedAt  DateTime?
  archivedBy  String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  payments Payment[]

  @@index([landlordId, type])
  @@index([landlordId, status])
}

model BankAccount {
  id                  String       @id @default(cuid())
  landlordId          String
  bankName            String
  accountName         String?
  accountNumberMasked String
  branch              String?
  swiftCode           String?
  routingInfo         String?
  isDefault           Boolean      @default(false)
  status              RecordStatus @default(ACTIVE)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  archivedAt          DateTime?
  archivedBy          String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])

  @@index([landlordId, status])
}

model Expense {
  id          String       @id @default(cuid())
  landlordId  String
  propertyId  String
  unitId      String?
  category    String
  vendor      String?
  amount      Decimal
  expenseDate DateTime
  receiptUrl  String?
  description String?
  status      RecordStatus @default(ACTIVE)
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  voidedAt    DateTime?
  voidedBy    String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  property Property        @relation(fields: [propertyId], references: [id])
  unit     Unit?           @relation(fields: [unitId], references: [id])
}

model MaintenanceRequest {
  id             String            @id @default(cuid())
  landlordId     String
  tenantId       String?
  propertyId     String
  unitId         String?
  title          String
  description    String
  priority       String            @default("normal")
  status         MaintenanceStatus @default(OPEN)
  estimatedCost  Decimal?
  finalCost      Decimal?
  contractorName String?
  photoUrl       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  archivedAt     DateTime?
  archivedBy     String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  tenant   Tenant?         @relation(fields: [tenantId], references: [id])
  property Property        @relation(fields: [propertyId], references: [id])
  unit     Unit?           @relation(fields: [unitId], references: [id])
}

model Document {
  id           String       @id @default(cuid())
  landlordId   String
  propertyId   String?
  unitId       String?
  tenantId     String?
  leaseId      String?
  documentType String
  fileName     String
  fileUrl      String
  status       RecordStatus @default(ACTIVE)
  uploadedBy   String
  createdAt    DateTime     @default(now())
  archivedAt   DateTime?
  archivedBy   String?

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  property Property?       @relation(fields: [propertyId], references: [id])
  unit     Unit?           @relation(fields: [unitId], references: [id])
  tenant   Tenant?         @relation(fields: [tenantId], references: [id])
  lease    Lease?          @relation(fields: [leaseId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  landlordId String
  senderId   String
  receiverId String
  propertyId String?
  unitId     String?
  subject    String
  message    String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  landlord LandlordProfile @relation(fields: [landlordId], references: [id])
  sender   User            @relation("Sender", fields: [senderId], references: [id])
  receiver User            @relation("Receiver", fields: [receiverId], references: [id])
}

model AuditLog {
  id           String   @id @default(cuid())
  landlordId   String?
  actorUserId  String
  actorEmail   String
  action       String
  entityType   String
  entityId     String
  targetUserId String?
  targetEmail  String?
  details      Json
  createdAt    DateTime @default(now())

  landlord LandlordProfile? @relation(fields: [landlordId], references: [id])
  actor    User             @relation("AuditActor", fields: [actorUserId], references: [id])
}
